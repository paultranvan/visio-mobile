{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "visio-mobile",
  "version": "0.4.0",
  "identifier": "io.visio.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "frontend/dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Visio Mobile",
        "width": 960,
        "height": 720,
        "minWidth": 320,
        "minHeight": 480
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["visio"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../i18n/*.json": "i18n/",
      "../../assets/backgrounds/*.jpg": "backgrounds/",
      "../../models/selfie_segmentation.onnx": "models/"
    },
    "icon": [
        "icons/icon.png",
        "icons/icon.icns",
        "icons/icon.ico",
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png"
      ]
  }
}
